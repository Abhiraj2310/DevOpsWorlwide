---
const base = import.meta.env.BASE_URL;
const links = [['Home',base],['Articles',`${base}articles`],['Categories',`${base}categories`],['Tags',`${base}tags`],['Archives',`${base}archives`],['About',`${base}about`]];
---
<header class="sticky top-0 z-50 border-b border-slate-700/40 bg-slate-950/75 backdrop-blur-xl"><div class="shell flex h-16 items-center justify-between"><a href={base} class="font-black tracking-tight text-lg">DevOps <span class="gradient">Globe</span></a><nav class="hidden md:flex gap-5 text-sm text-slate-300">{links.map(([name,href])=><a class="hover:text-white" href={href}>{name}</a>)}</nav><div class="flex items-center gap-3"><a href={`${base}search`} aria-label="Search" class="text-xl">Search</a><button id="theme" aria-label="Toggle colour theme" class="rounded-full border border-slate-600 px-2 py-1 text-xs">Theme</button><a href="https://github.com" class="hidden sm:block text-sm" aria-label="GitHub">GitHub</a></div></div></header>
<script>document.querySelector('#theme')?.addEventListener('click',()=>document.documentElement.classList.toggle('light'));</script>
