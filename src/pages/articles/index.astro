---
import { getCollection } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import BlogCard from '../../components/BlogCard.astro'; const posts=(await getCollection('blog',({data})=>!data.draft)).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf());
---
<BaseLayout title="Articles | DevOpsWorlwide"><section class="shell py-16"><p class="eyebrow">Library</p><h1 class="text-5xl font-black">All articles</h1><p class="prose-lead mt-3">Systems thinking for people who build and run production.</p><div class="card mt-8 p-4"><label class="sr-only" for="filter">Filter articles</label><input id="filter" class="w-full bg-transparent text-lg outline-none" placeholder="Search articles, tags, categories…"/></div><div class="mt-5 flex flex-wrap gap-2">{['Kubernetes','AWS','Docker','Terraform','Linux','Jenkins','GitHub','Azure','GCP','AI','Security','Observability'].map(x=><button class="tag filter-tag" data-filter={x}>{x}</button>)}</div><div id="list" class="mt-8 grid gap-5 md:grid-cols-3">{posts.map(post=><div data-search={`${post.data.title} ${post.data.tags.join(' ')} ${post.data.category}`}><BlogCard post={post}/></div>)}</div></section></BaseLayout><script>const input=document.querySelector('#filter');const cards=[...document.querySelectorAll('#list>div')];const run=()=>{const q=input.value.toLowerCase();cards.forEach(c=>c.style.display=c.dataset.search.toLowerCase().includes(q)?'':'none')};const category=new URLSearchParams(location.search).get('category');if(category)input.value=category;input?.addEventListener('input',run);document.querySelectorAll('.filter-tag').forEach(b=>b.addEventListener('click',()=>{input.value=b.dataset.filter;run()}));run();</script>
