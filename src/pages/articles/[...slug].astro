---
import { getCollection, render } from 'astro:content'; import BaseLayout from '../../layouts/BaseLayout.astro'; import BlogCard from '../../components/BlogCard.astro';
export async function getStaticPaths(){const posts=await getCollection('blog',({data})=>!data.draft);return posts.map(post=>({params:{slug:post.id},props:{post}}));}
const {post}=Astro.props; const {Content,headings}=await render(post); const related=(await getCollection('blog')).filter(p=>p.id!==post.id&&p.data.tags.some(t=>post.data.tags.includes(t))).slice(0,3); const d=post.data;
const jsonLd={"@context":"https://schema.org","@type":"BlogPosting",headline:d.title,description:d.description,datePublished:d.date.toISOString(),author:{"@type":"Person",name:d.author},publisher:{"@type":"Organization",name:"DevOps Globe"}};
---
<BaseLayout title={`${d.title} | DevOps Globe`} description={d.description}><script type="application/ld+json" set:html={JSON.stringify(jsonLd)}/><div class="fixed left-0 top-16 z-40 h-1 bg-gradient-to-r from-blue-400 to-purple-400" id="progress"></div><section class="shell py-12"><p class="text-sm text-slate-400"><a href="/">Home</a> / <a href="/articles">Articles</a> / {d.category}</p><div class="mt-7 grid gap-10 lg:grid-cols-[minmax(0,1fr)_250px]"><article><p class="eyebrow">{d.category}</p><h1 class="mt-3 text-4xl font-black leading-tight md:text-6xl">{d.title}</h1><p class="prose-lead mt-5">{d.description}</p><div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-slate-400"><span>By {d.author}</span><span>·</span><time datetime={d.date.toISOString()}>{d.date.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</time><span>·</span><span>{d.readingTime} min read</span></div><div class="card mt-8 flex h-64 items-end bg-gradient-to-br from-blue-600 via-indigo-700 to-purple-800 p-7 text-6xl">☁</div><div class="article-body mt-10"><Content/></div><div class="mt-10 flex gap-2 border-y border-slate-700/50 py-5"><span class="text-slate-400">Share:</span><button class="tag">LinkedIn</button><button class="tag">X</button><button class="tag">Copy link</button></div><section class="card mt-10 p-6"><p class="eyebrow">Written by</p><h2 class="mt-1 text-xl font-bold">{d.author}</h2><p class="text-slate-400">Independent editor covering practical cloud operations and reliable delivery systems.</p></section></article><aside class="hidden lg:block"><div class="sticky top-24 card p-5"><p class="font-bold">On this page</p><ol class="mt-3 space-y-2 text-sm text-slate-400">{headings.filter(h=>h.depth<=3).map(h=><li class:list={h.depth===3&&'ml-3'}><a href={`#${h.slug}`}>{h.text}</a></li>)}</ol></div></aside></div></section><section class="shell"><h2 class="text-2xl font-bold">Related reading</h2><div class="mt-5 grid gap-5 md:grid-cols-3">{related.map(post=><BlogCard post={post}/>)}</div><div class="card mt-10 p-6 text-center text-slate-400">Comments are coming soon — Giscus integration is ready for a future release.</div></section></BaseLayout><script>addEventListener('scroll',()=>document.querySelector('#progress').style.width=`${scrollY/(document.body.scrollHeight-innerHeight)*100}%`)</script>
