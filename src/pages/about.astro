---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | DevOpsWorldwide">
  <section class="shell max-w-4xl py-16">
    <p class="eyebrow">About DevOpsWorldwide</p>
    <h1 class="mt-3 text-5xl font-black">For the people behind reliable software.</h1>
    <p class="prose-lead mt-6">DevOpsWorldwide translates the fast-moving world of infrastructure into practical context: what changed, why it matters, and what to do next.</p>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <div class="card p-6">
        <h2 class="text-xl font-bold">Our mission</h2>
        <p class="mt-3 text-slate-400">Make operational knowledge generous, specific, and useful across every cloud and every team shape.</p>
      </div>
      <div class="card p-6">
        <h2 class="text-xl font-bold">Editorial focus</h2>
        <p class="mt-3 text-slate-400">Kubernetes · SRE · Observability · IaC · Security · Cloud economics</p>
      </div>
    </div>

    <section class="card mt-8 p-7 md:p-8" aria-labelledby="founder-editor">
      <p class="eyebrow">The editorial desk</p>
      <h2 id="founder-editor" class="mt-2 text-3xl font-bold">Abhiraj Kharbade — Founder &amp; Editor</h2>
      <p class="mt-4 text-lg leading-8 text-slate-300">An engineer with a passion for DevOps and Cloud Engineering, Abhiraj works as a Senior Site Reliability Engineer and Subject Matter Expert for Cloud and Automation. Through DevOpsWorldwide, he shares clear, experience-led guides for teams building and operating modern systems.</p>
      <p class="mt-4 leading-7 text-slate-400">The editorial lens spans DevOps, cloud, SRE, platform engineering, observability, and AI-assisted operations—always with an emphasis on useful decisions, dependable delivery, and engineers staying in control.</p>
      <div class="mt-6 flex flex-wrap gap-x-5 gap-y-3 text-sm">
        <a class="text-indigo-300 hover:text-indigo-200" href="mailto:admin@devopsworldwide.com">admin@devopsworldwide.com</a>
        <a class="text-indigo-300 hover:text-indigo-200" href="https://www.linkedin.com/company/devopsworldwide/" target="_blank" rel="noopener noreferrer">Follow DevOpsWorldwide on LinkedIn</a>
      </div>
    </section>

    <h2 class="mt-14 text-3xl font-bold">Our timeline</h2>
    <ol class="mt-6 border-l border-indigo-400 pl-6 text-slate-400">
      <li class="mb-6"><b class="text-white">2024 — The idea</b><br />A calmer place for engineering signal.</li>
      <li class="mb-6"><b class="text-white">2025 — Editorial desk</b><br />Monthly deep dives begin.</li>
      <li><b class="text-white">2026 — DevOpsWorldwide</b><br />A global conversation for modern operators.</li>
    </ol>
  </section>
</BaseLayout>
