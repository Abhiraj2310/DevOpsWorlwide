---
import { getCollection } from 'astro:content'; import BaseLayout from '../layouts/BaseLayout.astro'; import BlogCard from '../components/BlogCard.astro';
const posts=(await getCollection('blog',({data})=>!data.draft)).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf()); const featured=posts.find(p=>p.data.featured)??posts[0];
---
<BaseLayout><section class="shell py-20 md:py-28"><p class="eyebrow">DevOps field notes · July 2026</p><h1 class="mt-4 max-w-4xl text-5xl font-black tracking-tight md:text-7xl">The operating system for <span class="gradient">modern engineering.</span></h1><p class="prose-lead mt-6 max-w-2xl">Clear, useful intelligence for builders navigating cloud-native systems, reliability, security, and the changing craft of delivery.</p><div class="mt-8 flex flex-wrap gap-3"><a class="btn" href="/articles">Read the latest →</a><a class="btn ghost" href="/about">Our mission</a></div><div class="mt-12 grid grid-cols-3 gap-3 text-center"><div class="card p-4"><b class="text-2xl gradient">10</b><br/><span class="text-xs text-slate-400">Deep dives</span></div><div class="card p-4"><b class="text-2xl gradient">24</b><br/><span class="text-xs text-slate-400">Topics</span></div><div class="card p-4"><b class="text-2xl gradient">100%</b><br/><span class="text-xs text-slate-400">Independent</span></div></div></section><section class="shell"><div class="flex items-end justify-between"><div><p class="eyebrow">Featured signal</p><h2 class="text-3xl font-bold">Worth your full attention</h2></div><a class="text-sm text-indigo-300" href="/articles">View all →</a></div><div class="mt-6">{featured&&<BlogCard post={featured} wide/>}</div></section><section class="shell mt-20"><p class="eyebrow">Latest articles</p><h2 class="text-3xl font-bold">What operators are reading</h2><div class="mt-6 grid gap-5 md:grid-cols-3">{posts.slice(0,6).map(post=><BlogCard post={post}/>)}</div></section><section class="shell mt-20 grid gap-6 md:grid-cols-2"><div class="card p-7"><p class="eyebrow">Trending topics</p><h2 class="mt-2 text-2xl font-bold">Follow the signals</h2><p class="mt-3 text-slate-400">Kubernetes · Platform Engineering · FinOps · AI Ops · Observability · DevSecOps</p></div><div class="card p-7"><p class="eyebrow">Monthly dispatch</p><h2 class="mt-2 text-2xl font-bold">One useful email. No noise.</h2><form class="mt-4 flex gap-2"><input aria-label="Email address" class="w-full rounded-xl border border-slate-600 bg-slate-950 px-3" placeholder="you@company.com" type="email"/><button class="btn" type="button">Subscribe</button></form></div></section></BaseLayout>
