---
import { getCollection } from 'astro:content'; import BaseLayout from '../layouts/BaseLayout.astro'; const posts=(await getCollection('blog')).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf()); const groups=posts.reduce<Record<string, typeof posts>>((acc,post)=>{const month=post.data.date.toLocaleDateString('en-US',{month:'long',year:'numeric'});(acc[month]??=[]).push(post);return acc;},{});
---
<BaseLayout title="Archives | DevOpsWorlwide"><section class="shell max-w-3xl py-16"><p class="eyebrow">The record</p><h1 class="text-5xl font-black">Archives</h1>{Object.entries(groups).map(([month,items])=><section class="mt-10"><h2 class="text-xl font-bold">{month}</h2><ul class="mt-3 divide-y divide-slate-700/50">{items?.map(p=><li class="py-3"><a class="hover:text-indigo-300" href={`/articles/${p.id}`}>{p.data.title}</a><span class="float-right text-sm text-slate-500">{p.data.readingTime} min</span></li>)}</ul></section>)}</section></BaseLayout>
