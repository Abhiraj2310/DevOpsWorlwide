---
const base = import.meta.env.BASE_URL;
const links = [['Home', base], ['Articles', `${base}articles`], ['Categories', `${base}categories`], ['Tags', `${base}tags`], ['Archives', `${base}archives`], ['About', `${base}about`]];
---

<header class="sticky top-0 z-50 border-b border-slate-700/40 bg-slate-950/75 backdrop-blur-xl">
  <div class="shell flex h-16 items-center justify-between">
    <a href={base} class="font-black tracking-tight text-lg"><span class="gradient">DevOpsWorldwide</span></a>
    <nav class="hidden md:flex gap-5 text-sm text-slate-300">{links.map(([name, href]) => <a class="hover:text-white" href={href}>{name}</a>)}</nav>
    <div class="flex items-center gap-3">
      <a href={`${base}search`} aria-label="Search" class="text-xl">Search</a>
      <button id="theme" type="button" aria-label="Switch to light theme" aria-pressed="false" class="rounded-full border border-slate-600 px-3 py-1.5 text-xs font-bold">Light mode</button>
      <a href="https://github.com" class="hidden sm:block text-sm" aria-label="GitHub">GitHub</a>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector('#theme');
  const updateThemeButton = () => {
    const isLight = document.documentElement.classList.contains('light');
    button?.setAttribute('aria-pressed', String(isLight));
    button?.setAttribute('aria-label', isLight ? 'Switch to dark theme' : 'Switch to light theme');
    if (button) button.textContent = isLight ? 'Dark mode' : 'Light mode';
  };
  updateThemeButton();
  button?.addEventListener('click', () => {
    document.documentElement.classList.toggle('light');
    try { localStorage.setItem('devopsworldwide-theme', document.documentElement.classList.contains('light') ? 'light' : 'dark'); } catch {}
    updateThemeButton();
  });
</script>
