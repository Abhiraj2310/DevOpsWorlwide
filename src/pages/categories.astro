---
import { getCollection } from 'astro:content'; import BaseLayout from '../layouts/BaseLayout.astro'; const posts=await getCollection('blog'); const cats=[...new Set(posts.map(p=>p.data.category))];
---
<BaseLayout title="Categories | DevOpsWorlwide"><section class="shell py-16"><p class="eyebrow">Browse by focus</p><h1 class="text-5xl font-black">Categories</h1><div class="mt-8 grid gap-4 sm:grid-cols-2 md:grid-cols-3">{cats.map(c=><a class="card p-6 hover:border-indigo-400" href={`${import.meta.env.BASE_URL}articles?category=${encodeURIComponent(c)}`}><p class="text-2xl">◈</p><h2 class="mt-4 font-bold text-xl">{c}</h2><p class="text-sm text-slate-400">{posts.filter(p=>p.data.category===c).length} article{posts.filter(p=>p.data.category===c).length!==1?'s':''}</p></a>)}</div></section></BaseLayout>
