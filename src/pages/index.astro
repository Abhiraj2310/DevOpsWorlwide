---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.filter((post) => post.id !== featured?.id).slice(0, 6);
const categoryCount = new Set(posts.map((post) => post.data.category)).size;
---

<BaseLayout>
  <section class="shell py-12 md:py-20">
    <div class="homepage-hero relative isolate overflow-hidden rounded-[2rem] border border-indigo-300/20 bg-slate-950 shadow-2xl shadow-indigo-950/50">
      <img class="homepage-hero-art absolute -z-20 h-full object-cover" src="/images/site/devopsworldwide-home-hero.png" alt="DevOpsWorldwide cloud, AI, and platform engineering illustration" />
      <div class="homepage-hero-shade absolute inset-0 -z-10"></div>
      <h1 class="sr-only">DevOpsWorldwide: engineering intelligence for modern operators</h1>
      <div class="homepage-hero-content absolute bottom-6 right-6 flex flex-wrap justify-end gap-3 md:bottom-10 md:right-10">
        <a class="btn" href={`${import.meta.env.BASE_URL}articles`}>Explore articles →</a>
        <a class="btn ghost" href={`${import.meta.env.BASE_URL}about`}>Our mission</a>
      </div>
    </div>

    <div class="mt-5 grid grid-cols-3 gap-3 text-center">
      <div class="card p-4"><b class="text-2xl gradient">{posts.length}</b><br/><span class="text-xs text-slate-400">Published articles</span></div>
      <div class="card p-4"><b class="text-2xl gradient">{categoryCount}</b><br/><span class="text-xs text-slate-400">Focus areas</span></div>
      <div class="card p-4"><b class="text-2xl gradient">100%</b><br/><span class="text-xs text-slate-400">Independent editorial</span></div>
    </div>
  </section>

  <section class="shell">
    <div class="flex items-end justify-between">
      <div><p class="eyebrow">Featured signal</p><h2 class="text-3xl font-bold">Worth your full attention</h2></div>
      <a class="text-sm text-indigo-300" href={`${import.meta.env.BASE_URL}articles`}>View all →</a>
    </div>
    <div class="mt-6">{featured && <BlogCard post={featured} wide />}</div>
  </section>

  <section class="shell mt-20">
    <p class="eyebrow">Latest articles</p><h2 class="text-3xl font-bold">What operators are reading</h2>
    <div class="mt-6 grid gap-5 md:grid-cols-3">{latestPosts.map((post) => <BlogCard post={post} />)}</div>
  </section>

  <section class="shell mt-20 grid gap-6 md:grid-cols-2">
    <div class="card p-7"><p class="eyebrow">Trending topics</p><h2 class="mt-2 text-2xl font-bold">Follow the signals</h2><p class="mt-3 text-slate-400">Kubernetes · Platform Engineering · FinOps · AI Ops · Observability · DevSecOps</p></div>
    <div class="card p-7"><p class="eyebrow">Monthly dispatch</p><h2 class="mt-2 text-2xl font-bold">One useful email. No noise.</h2><form id="subscribe" class="mt-4 flex gap-2"><input name="email" aria-label="Email address" class="w-full rounded-xl border border-slate-600 bg-slate-950 px-3" placeholder="you@company.com" type="email" required/><button class="btn" type="submit">Subscribe</button></form><p id="subscribe-status" class="mt-3 text-sm text-slate-400" aria-live="polite"></p></div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector('#subscribe');
  const status = document.querySelector('#subscribe-status');
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const email = new FormData(form).get('email');
    if (typeof email !== 'string' || !email) {
      status.textContent = 'Enter a valid email address.';
      return;
    }
    status.textContent = 'Opening your email app to confirm your subscription.';
    location.href = `mailto:admin@devopsworldwide.com?subject=${encodeURIComponent('DevOpsWorldwide newsletter subscription')}&body=${encodeURIComponent(`Please subscribe this email address: ${email}`)}`;
  });
</script>
