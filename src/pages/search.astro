---
import { getCollection } from 'astro:content'; import BaseLayout from '../layouts/BaseLayout.astro'; const posts=await getCollection('blog');
---
<BaseLayout title="Search | DevOpsWorldwide"><section class="shell max-w-3xl py-16"><p class="eyebrow">Find a signal</p><h1 class="text-5xl font-black">Search</h1><input id="search" autofocus class="card mt-8 w-full p-4 text-lg outline-none" placeholder="Try Kubernetes, FinOps, security…"/><div id="results" class="mt-6">{posts.map(p=><a class="result block border-b border-slate-700/50 py-5" data-text={`${p.data.title} ${p.data.description} ${p.data.tags.join(' ')}`} href={`${import.meta.env.BASE_URL}articles/${p.id}`}><h2 class="font-bold text-xl">{p.data.title}</h2><p class="text-sm text-slate-400">{p.data.description}</p></a>)}</div></section></BaseLayout><script>const q=new URLSearchParams(location.search).get('q');const s=document.querySelector('#search');s.value=q||'';const rows=[...document.querySelectorAll('.result')];const run=()=>rows.forEach(r=>r.style.display=r.dataset.text.toLowerCase().includes(s.value.toLowerCase())?'block':'none');s.addEventListener('input',run);run();</script>
